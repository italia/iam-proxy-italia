SATOSA_HOSTNAME=iam-proxy-italia.example.org
SATOSA_BASE=https://${SATOSA_HOSTNAME:-iam-proxy-italia.example.org}
SATOSA_BASE_STATIC=${SATOSA_BASE}/static
SATOSA_DISCO_SRV=${SATOSA_BASE_STATIC}/disco.html
SATOSA_UNKNOW_ERROR_REDIRECT_PAGE=${SATOSA_BASE_STATIC}/error_page.html

# ENDPOINT
FEDERATION_RESOLVE_ENDPOINT=resolve
FEDERATION_LEGAL_INFORMATION_URI=en/website/legal-information
SAMPLE_CIE_LOGO_URI=cie/sample-cie-logo.png
OPENID_RP_JWKS_URI=openid_relying_party/jwks.json
OPENID_RP_SIGNED_JWKS_URI=openid_relying_party/jwks.jose
OPENID_RP_CALLBACK_URI=oidc/callback
DEMO_RELYING_PARTY_FQDN=localhost:8090
# ENDPOINT

# DEMO SECTION
WELL_KNOW_OPENID_CONFIGURATION=https://${SATOSA_HOSTNAME:-iam-proxy-italia.example.org}/OIDCOP/.well-known/openid-configuration

# CIE OIDC: trust anchor and provider URLs. run-docker-compose.sh adds TRUST_ANCHOR_HOSTNAME and cie-provider.example.org to /etc/hosts.
# For local dev without Docker: TRUST_ANCHOR_URL=http://127.0.0.1:5002 OPENID_CIE_PROVIDER_URL=http://127.0.0.1:8002/oidc/op/
TRUST_ANCHOR_HOSTNAME=trust-anchor.example.org
TRUST_ANCHOR_URL=http://${TRUST_ANCHOR_HOSTNAME}:5002
OPENID_CIE_PROVIDER_URL=http://cie-provider.example.org:8002/oidc/op
# Wallet instance demo
DEMO_WALLET_INSTANCE_HOSTNAME=demo-wi.example.org
WALLET_INSTANCE_PORT=8080
WALLET_INSTANCE_CONFIG_DIR=./wallet-instance-demo/config
# URL where the wallet provider serves its federation entity config. Must match hostname:port above.
WALLET_PROVIDER_URL=http://demo-wi.example.org:8080/provider
# PagoPA CLI demo: Service name used in the CLI configuration. Must match the one in the CLI config file (example.config.ini).
PAGOPA_CLI_SERVICE_NAME=pagopa-wallet-cli

# END DEMO SECTION

# CLIENT
OPENID_RP_CLIENT_ID=${SATOSA_BASE}/CieOidcRp

# Set Time Zone
TZ="Europe/Rome"

# MongoDB: shared defaults for single-instance setup.
# Four component-specific prefixes (CIE OIDC, OpenID4VP, oidcop, OpenID4VCI) fall back to these.
# Override MONGO_CIE_OIDC_BACKEND_*, MONGO_PYEUDIW_OPENID4VP_*, MONGO_OIDCOP_*, MONGO_PYEUDIW_OPENID4VCI_* for separate DBs.
# See docs/mongodb-env.md
MONGO_URL=satosa-mongo
MONGO_PORT=27017
MONGO_DBUSER=satosa
MONGO_DBPASSWORD=thatpassword

# CIE OIDC backend collections (override only if needed)
# MONGO_CIE_OIDC_BACKEND_DB_NAME=cie_oidc
# MONGO_CIE_OIDC_BACKEND_AUTH_COLLECTION=cie_oidc_authentication
# MONGO_CIE_OIDC_BACKEND_TOKEN_COLLECTION=cie_oidc_authentication_token
# MONGO_CIE_OIDC_BACKEND_USER_COLLECTION=cie_oidc_users
# MONGO_CIE_OIDC_BACKEND_TRUST_CHAIN_COLLECTION=cie_oidc_trust_chains

# Mongo express authentication
EXPRESS_USER=satosauser
EXPRESS_PASSWORD=satosapw

# The path containing your secrets
SATOSA_KEYS_FOLDER=./pki
# Keys filename
SATOSA_PRIVATE_KEY_FILENAME=privkey.pem
SATOSA_PUBLIC_KEY_FILENAME=cert.pem

# BE CAREFUL HERE!
SATOSA_SALT=CHANGE_ME!
SATOSA_ENCRYPTION_KEY=CHANGE_ME!
SATOSA_STATE_ENCRYPTION_KEY=CHANGE_ME!
SATOSA_USER_ID_HASH_SALT=CHANGE_ME!

# Auto update idp metadata and keys
SATOSA_GET_IDEM_MDQ_KEY=true
SATOSA_GET_SPID_IDP_METADATA=true
SATOSA_GET_FICEP_IDP_METADATA=true
SATOSA_GET_CIE_IDP_METADATA=true

# Contact person data
SATOSA_CONTACT_PERSON_EMAIL_ADDRESS=support.example@organization.org
SATOSA_CONTACT_PERSON_TELEPHONE_NUMBER=+3906123456789
SATOSA_CONTACT_PERSON_FISCALCODE=01234567890
SATOSA_CONTACT_PERSON_GIVEN_NAME=Name
SATOSA_CONTACT_PERSON_IPA_CODE=ipa00c
SATOSA_CONTACT_PERSON_MUNICIPALITY=H501

# Organization data
SATOSA_ORGANIZATION_DISPLAY_NAME_EN="Example Organization"
SATOSA_ORGANIZATION_DISPLAY_NAME_IT="Example Organization"
SATOSA_ORGANIZATION_NAME_EN="example_organization"
SATOSA_ORGANIZATION_NAME_IT="example_organization"
SATOSA_ORGANIZATION_URL_EN="https://example_organization.org"
SATOSA_ORGANIZATION_URL_IT="https://example_organization.org/it"

SATOSA_UI_DESCRIPTION_EN="Resource description"
SATOSA_UI_DESCRIPTION_IT="Resource description"
SATOSA_UI_DISPLAY_NAME_EN="Resource Display Name"
SATOSA_UI_DISPLAY_NAME_IT="Resource Display Name"
SATOSA_UI_INFORMATION_URL_EN="https://example_organization.org/information_url"
SATOSA_UI_INFORMATION_URL_IT="https://example_organization.org/it/information_url"
SATOSA_UI_LOGO_HEIGHT="60"
SATOSA_UI_LOGO_WIDTH="80"
SATOSA_UI_LOGO_URL="https://example_organization.org/logo.png"
SATOSA_UI_PRIVACY_URL_EN="https://example_organization.org/privacy"
SATOSA_UI_PRIVACY_URL_IT="https://example_organization.org/it/privacy"

# If set to true, satosa downloads IDEM's keys and IDPs from registry.spid.gov.it
GET_IDEM_MDQ_KEY=true

# CERT BOT VARIABLE
# Two values may be available:
# local and certbot
# local used for development and/or demo purposes
# certbot used in the production environment
CERT_METHOD=local
CERTBOT_KTY=3072
CERTBOT_DAYS=365

# PAGOPA CLI CUSTOM CONFIG
CUSTOM_CONFIG_PATH=example.pagopa_cli.config.ini